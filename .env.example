# ---- Application ----
NODE_ENV=production
# Public base URL (used in emails / links)
APP_URL=https://budget.aws.uned.live

# ---- Database ----
# Inside Docker the hostname is the mongo service name "db".
MONGODB_URI=mongodb://db:27017/london_academy

# ---- Security ----
# Generate a long random value:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-string
# JWT lifetime
JWT_EXPIRES_IN=7d

# ---- Bootstrap Super-Admin (created automatically on first boot) ----
ADMIN_EMAIL=rachel@londonacademy.co.il
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_NAME=Rachel

# ---- Email notifications (NodeMailer) ----
# Leave SMTP_HOST empty to disable email (submissions still work, just no alerts).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="London Academy <no-reply@londonacademy.co.il>"
# Where new-lead / new-teacher alerts are sent (defaults to ADMIN_EMAIL)
ALERT_EMAIL=

# ---- Uploads ----
UPLOAD_DIR=/app/uploads
